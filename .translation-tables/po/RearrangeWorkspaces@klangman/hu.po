#. metadata.json->name
msgid "Rearrange Workspaces"
msgstr "Munkaterületek átrendezése"

#. metadata.json->description
msgid "Allows you to rearrange Cinnamon desktop workspaces"
msgstr ""
"Lehetővé teszi a Cinnamon asztali munkaterületek átrendezését"

#. 5.4->settings-schema.json->keybinding-header->description
msgid "Hotkeys to move the current workspace"
msgstr "Gyorsbillentyűk az aktuális munkaterület mozgatásához"

#. 5.4->settings-schema.json->left-key->description
msgid "Move workspace to the left"
msgstr "Munkaterület áthelyezése balra"

#. 5.4->settings-schema.json->right-key->description
msgid "Move workspace to the right"
msgstr "Munkaterület áthelyezése jobbra"
