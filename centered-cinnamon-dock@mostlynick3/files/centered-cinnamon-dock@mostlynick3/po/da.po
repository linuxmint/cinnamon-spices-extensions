msgid "Don't shift windows (disable panel struts)"
msgstr "Undgå at flytte vinduer (deaktivér panelstiverne)"

#. 6.4/extension.js:275
msgid "Fade animation duration (ms)"
msgstr "Varighed af udtoningsanimation (ms)"

#. 6.4/extension.js:282
msgid "Appearance"
msgstr "Udseende"

#. 6.4/extension.js:285
msgid "Transparency (%)"
msgstr "Gennemsigtighed (%)"

#. 6.4/extension.js:293
msgid "Minimum dock width"
msgstr "Mindste dokbredde"

#. 6.4/extension.js:301
msgid "Enable zoom effect on hover"
msgstr "Aktivér zoomeffekt, når musemarkøren er over"

#. 6.4/extension.js:306
msgid "Zoom scale factor"
msgstr "Zoomskaleringsfaktor"

#. 6.4/extension.js:313
msgid "Auto-hide Behavior"
msgstr "Opførsel for autoskjul"

#. 6.4/extension.js:316
msgid "Choose one auto-hide mode (mutually exclusive):"
msgstr "Vælg én tilstand for autoskjul (de udelukker hinanden):"

#. 6.4/extension.js:329
msgid "Auto-hide dock when focusing apps"
msgstr "Skjul automatisk dok, når program får fokus"

#. 6.4/extension.js:334
msgid "    ↳ Show dock when no window is focused"
msgstr "    ↳ Vis dok, når intet vindue har fokus"

#. 6.4/extension.js:341
msgid "Show dock unless window covers full screen"
msgstr "Vis dok, medmindre vinduet dækker hele skærmen"

#. 6.4/extension.js:346
msgid "(Dock visible unless a window covers the full screen)"
msgstr "(Dokken er synlig, medmindre et vindue dækker hele skærmen)"

