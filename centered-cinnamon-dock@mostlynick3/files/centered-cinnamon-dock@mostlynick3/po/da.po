#. 6.4/extension.js:68
msgid "Welcome to Centered Cinnamon Dock!"
msgstr "Velkommen til Centreret Cinnamon-dok!"

#. 6.4/extension.js:76
msgid "Which panel(s) would you like to turn into a dock?"
msgstr "Hvilke paneler vil du gerne omdanne til en dok?"

#. 6.4/extension.js:124
msgid "Right click any panel to change your mind or configure the docks later."
msgstr ""
"Højreklik et panel for at ændre mening eller konfigurere dokkene på et "
"senere tidspunkt."

#. 6.4/extension.js:134
msgid "Skip"
msgstr "Spring over"

#. 6.4/extension.js:135
msgid "Enable"
msgstr "Aktivér"

#. 6.4/extension.js:202
#, javascript-format
msgid "Bottom Panel (Monitor %d)"
msgstr "Nederste panel (skærm %d)"

