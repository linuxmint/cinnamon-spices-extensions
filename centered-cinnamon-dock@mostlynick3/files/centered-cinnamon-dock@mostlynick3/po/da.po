msgid "Auto-hide Indicator"
msgstr "Autoskjulindikator"

#. 6.4/extension.js:384
msgid "Show indicator of dock location in trigger zone"
msgstr "Vis indikator for dokplacering i udløserområdet"

#. 6.4/extension.js:389
msgid "Indicator color"
msgstr "Indikatorfarve"

#. 6.4/extension.js:663
msgid "Hex color:"
msgstr "Hex-farve:"

#. 6.4/extension.js:671
msgid "Type hex color"
msgstr "Indtast hex-farve"

#. metadata.json->name
msgid "Centered Cinnamon Dock"
msgstr "Centreret Cinnamon-dok"

#. metadata.json->description
msgid ""
"Centers the panel with dock styling and customization options. Configure per "
"panel by right-clicking it."
msgstr ""
"Centrerer panelet med dokdesign og tilpasningsmuligheder. Du kan konfigurere "
"hvert panel ved at højreklikke på det."
