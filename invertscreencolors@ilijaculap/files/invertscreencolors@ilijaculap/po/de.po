#. metadata.json->description
msgid ""
"This simple Cinnamon extension lets you invert either the entire screen or "
"only the active windows colors, with configurable keyboard shortcuts for "
"both."
msgstr ""
"Diese einfache Cinnamon Erweiterung ermöglicht die Farbumkehr für den "
"ganzen Bildschirm oder nur für ein aktives Fenster mit benutzerdefinierten "
"Tastenkombinationen."

#. metadata.json->name
msgid "Invert screen colors"
msgstr "Bildschirmfarben umkehren"

#. settings-schema.json->keybinding-header->description
msgid "Keyboard shortcuts"
msgstr "Tastenkombinationen"

#. settings-schema.json->kb-shortcut-fs->description
msgid "Invert colors for whole screen"
msgstr "Farbumkehr für den ganzen Bildschirm"

#. settings-schema.json->kb-shortcut-wd->description
msgid "Invert colors for active window"
msgstr "Farbumkehr für aktives Fenster"
