{
	"layout": {
		"type": "layout",
		"pages": [
			"general-page",
			"style-page"
		],
		"general-page": {
			"type": "page",
			"title": "General",
			"sections": [
				"general-section",
				"idle-section",
				"effects-section"
			]
		},
		"style-page": {
			"type": "page",
			"title": "Style",
			"sections": [
				"style-section",
				"colors-section"
			]
		},
		"general-section": {
			"type": "section",
			"title": "General",
			"keys": [
				"animation-mode",
				"animation-time",
				"deactivate-in-fullscreen",
				"pause-effects-binding"
			]
		},
		"idle-section": {
			"dependency": "mouse-idle-watcher-enabled",
			"type": "section",
			"title": "Idle",
			"keys": [
				"idle-animation-delay",
				"idle-animation-period",
				"idle-animation-mode"
			]
		},
		"effects-section": {
			"type": "section",
			"title": "Effects",
			"keys": [
				"left-click-effect-enabled",
				"middle-click-effect-enabled",
				"right-click-effect-enabled",
				"pause-animation-effects-enabled",
				"mouse-movement-tracker-enabled",
				"mouse-movement-tracker-persist-on-stopped-enabled",
				"mouse-idle-watcher-enabled"
			]
		},
		"style-section": {
			"type": "section",
			"title": "Style",
			"keys": [
				"icon-mode",
				"size",
				"general-opacity"
			]
		},
		"colors-section": {
			"type": "section",
			"title": "Colors",
			"keys": [
				"left-click-color",
				"middle-click-color",
				"right-click-color",
				"mouse-movement-color",
				"mouse-idle-watcher-color"
			]
		}
	},
	"icon-mode": {
		"type": "combobox",
		"default": 1,
		"description": "Icon Mode",
		"options": {
			"Simple": 1,
			"Trigun": 2,
			"Nublo": 3,
			"Risco": 4,
			"Wolf": 5,
			"Pincel": 6,
			"Claw": 7,
			"Metropoli": 8,
			"Flowey": 9,
			"Kusco": 10,
			"Ouroboros": 11,
			"Helix": 12,
			"Direction": 13,
			"Spinks": 14,
			"Thatch": 15,
			"Cotton": 16,
			"Circle": 17,
			"Gear": 18,
			"H-Star": 19,
			"Aim": 20
		}
	},
	"size": {
		"type": "spinbutton",
		"default": 70,
		"min": 20,
		"max": 120,
		"step": 5,
		"units": "px",
		"description": "Icon Size"
	},
	"animation-mode": {
		"type": "combobox",
		"default": "blink",
		"description": "Click Animation Mode",
		"options": {
			"Blink": "blink",
			"Bounce": "bounce",
			"Retract": "retract",
			"Expand": "expand"
		}
	},
	"animation-time": {
		"type": "spinbutton",
		"default": 400,
		"min": 100,
		"max": 5000,
		"step": 50,
		"units": "ms",
		"description": "Animation Time"
	},
	"idle-animation-mode": {
		"type": "combobox",
		"default": "blink",
		"description": "Idle Mouse Animation Mode",
		"dependency": "mouse-idle-watcher-enabled",
		"options": {
			"Blink": "blink",
			"Bounce": "bounce",
			"Retract": "retract",
			"Expand": "expand"
		}
	},
	"idle-animation-delay": {
		"type": "spinbutton",
		"dependency": "mouse-idle-watcher-enabled",
		"default": 10,
		"min": 1,
		"max": 120,
		"step": 1,
		"units": "min",
		"description": "Start Idle Animation After"
	},
	"idle-animation-period": {
		"type": "spinbutton",
		"dependency": "mouse-idle-watcher-enabled",
		"default": 400,
		"min": 100,
		"max": 5000,
		"step": 50,
		"units": "ms",
		"description": "Idle Mouse Animation Period"
	},
	"general-opacity": {
		"type": "spinbutton",
		"description": "General Opacity",
		"default": 185,
		"min": 5,
		"max": 255,
		"step": 5
	},
	"deactivate-in-fullscreen": {
		"type": "switch",
		"default": false,
		"description": "Deactivate In Fullscreen"
	},
	"pause-effects-binding": {
		"type": "keybinding",
		"description": "Pause Effects Keybinding",
		"default": "",
		"tooltip": "Set keybinding to pause or continue the effects"
	},
	"left-click-effect-enabled": {
		"type": "switch",
		"default": true,
		"description": "Animate Left Click"
	},
	"middle-click-effect-enabled": {
		"type": "switch",
		"default": true,
		"description": "Animate Middle Click"
	},
	"right-click-effect-enabled": {
		"type": "switch",
		"default": true,
		"description": "Animate Right Click"
	},
	"pause-animation-effects-enabled": {
		"type": "switch",
		"default": true,
		"description": "Animate Pause"
	},
	"mouse-movement-tracker-enabled": {
		"type": "switch",
		"default": false,
		"description": "Mouse Movement Tracker (experimental)",
		"tooltip": "This is still experimental and may interfere when clicking on the panel or in some drag-and-drop operations."
	},
	"mouse-movement-tracker-persist-on-stopped-enabled": {
		"type": "switch",
		"default": false,
		"description": "Persist Movement Tracker On Stopped (experimental)",
		"dependency": "mouse-movement-tracker-enabled",
		"tooltip": "This is still experimental and may interfere when clicking on the panel or in some drag-and-drop operations."
	},
	"mouse-idle-watcher-enabled": {
		"type": "switch",
		"default": false,
		"description": "Mouse Idle Watcher",
		"tooltip": "Displays animations when the system enters idle state."
	},
	"left-click-color": {
		"type": "colorchooser",
		"default": "#3B82F6",
		"description": "Left Click Color"
	},
	"middle-click-color": {
		"type": "colorchooser",
		"default": "#F59E0B",
		"description": "Middle Click Color"
	},
	"right-click-color": {
		"type": "colorchooser",
		"default": "#EF4444",
		"description": "Right Click Color"
	},
	"mouse-movement-color": {
		"type": "colorchooser",
		"default": "#06B6D4",
		"description": "Mouse Movement Tracker Color"
	},
	"mouse-idle-watcher-color": {
		"type": "colorchooser",
		"default": "#A855F7",
		"description": "Mouse Idle Watcher Color",
		"dependency": "mouse-idle-watcher-enabled"
	}
}
