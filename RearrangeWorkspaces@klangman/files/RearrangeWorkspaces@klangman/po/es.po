#. 5.4/extension.js:109 5.4/extension.js:118
#, javascript-format
msgid "Moved workspace to the left\n"
"Workspace is now at position %s"
msgstr "Se ha desplazado el espacio de trabajo hacia la izquierda\n"
"El espacio de trabajo se encuentra ahora en la posición %s"

#. 5.4/extension.js:127 5.4/extension.js:136
#, javascript-format
msgid "Moved workspace to the right\n"
"Workspace is now at position %s"
msgstr "Se ha desplazado el espacio de trabajo hacia la derecha\n"
"El espacio de trabajo se encuentra ahora en la posición %s"

#. metadata.json->name
msgid "Rearrange Workspaces"
msgstr "Reorganizar espacios de trabajo"

#. metadata.json->description
msgid "Allows you to rearrange Cinnamon desktop workspaces"
msgstr "Te permite reorganizar los espacios de trabajo del escritorio Cinnamon"

#. 5.4->settings-schema.json->keybinding-header->description
msgid "Hotkeys to move the current workspace"
msgstr "Teclas de acceso rápido para cambiar de espacio de trabajo"

#. 5.4->settings-schema.json->left-key->description
msgid "Move workspace to the left"
msgstr "Desplazar el área de trabajo hacia la izquierda"

#. 5.4->settings-schema.json->right-key->description
msgid "Move workspace to the right"
msgstr "Desplazar el espacio de trabajo hacia la derecha"

