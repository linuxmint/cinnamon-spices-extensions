{
    "head": {
        "type": "header",
        "description": "Borde de ventanas"
    },
    "border-color": {
        "type": "colorchooser",
        "default": "#444444",
        "description": "Color del borde"
    },
    "border-width": {
        "type": "spinbutton",
        "default": 3,
        "min": 1,
        "max": 20,
        "step": 1,
        "units": "px",
        "description": "Grosor del borde"
    },
    "border-radius": {
        "type": "spinbutton",
        "default": 12,
        "min": 0,
        "max": 30,
        "step": 1,
        "units": "px",
        "description": "Radio de esquinas redondeadas"
    },
    "hide-on-maximized": {
        "type": "switch",
        "default": false,
        "description": "Ocultar borde en ventanas maximizadas"
    }
}
